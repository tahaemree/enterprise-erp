# ==============================================================================
# NEXUS ERP - Environment Variables Template
# ==============================================================================
# ⚠️ IMPORTANT: DO NOT COMMIT REAL SECRETS TO THIS FILE ⚠️
# Copy this file to .env and fill in the values for your local environment.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
# Example PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nexuserp?schema=public"

# ------------------------------------------------------------------------------
# 2. NEXT AUTH (Authentication)
# ------------------------------------------------------------------------------
# NextAuth Secret used to encrypt JWT tokens.
# Generate a secure secret using: openssl rand -base64 32
AUTH_SECRET="your_super_secret_auth_string_here_min_32_chars"

# Base URL for the application (required for NextAuth in production)
NEXTAUTH_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# 3. ENCRYPTION (Field-Level Encryption at Rest)
# ------------------------------------------------------------------------------
# Used by src/lib/encryption.ts for encrypting PII data (IBAN, TaxId, etc.)
# ENCRYPTION_KEY must be exactly 32 bytes (256-bit) encoded as hex or string
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your_32_byte_encryption_key_here_"

# Salt for key derivation
# Generate using: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_SALT="your_unique_salt_here"

# ------------------------------------------------------------------------------
# 4. GIB E-INVOICE (e-Fatura Integration - Optional)
# ------------------------------------------------------------------------------
# Gelir İdaresi Başkanlığı (GIB) Test Credentials
GIB_USERNAME="gib_test_username"
GIB_PASSWORD="gib_test_password"
GIB_ENDPOINT="https://earsivwstest.efatura.gov.tr/earsivws/earsivWS"

# ------------------------------------------------------------------------------
# 5. REDIS (Rate Limiting & Caching - Optional)
# ------------------------------------------------------------------------------
# If you are using Redis for rate limiting (BullMQ / Upstash)
REDIS_URL="redis://localhost:6379"

# ------------------------------------------------------------------------------
# 6. SENTRY (Error Tracking - Optional)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
